{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "plain",
          "foreground": "#E6E6E6",
          "background": "transparent",
          "template": " {{ .Path }} ",
          "properties": {
            "style": "folder",
            "home_icon": "~"
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#8AB4F8",
          "background": "transparent",
          "template": " {{ .HEAD }}{{ if .Working.Changed }}*{{ end }} ",
          "properties": {
            "fetch_status": true
          }
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "#A0A0A0",
          "background": "transparent",
          "template": " {{ if gt .Code 0 }}x{{ .Code }}{{ end }} "
        }
      ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "segments": [
        {
          "type": "time",
          "style": "plain",
          "foreground": "#BDBDBD",
          "background": "transparent",
          "template": " {{ .CurrentDate | date \"15:04\" }} "
        }
      ]
    }
  ]
}
