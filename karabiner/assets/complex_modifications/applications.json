{
  "description": "Application focus sublayer (Hyper+A then B/T/N/F)",
  "manipulators": [
    {
      "from": {
        "key_code": "a",
        "modifiers": {
          "mandatory": [
            "left_command",
            "left_control",
            "left_option",
            "left_shift"
          ]
        }
      },
      "to": [
        {
          "set_variable": {
            "name": "app_layer",
            "value": 1
          }
        }
      ],
      "type": "basic"
    },
    {
      "conditions": [
        {
          "name": "app_layer",
          "type": "variable_if",
          "value": 1
        }
      ],
      "from": { "key_code": "b" },
      "to": [
        { "shell_command": "open -a Comet" },
        {
          "set_variable": {
            "name": "app_layer",
            "value": 0
          }
        }
      ],
      "type": "basic"
    },
